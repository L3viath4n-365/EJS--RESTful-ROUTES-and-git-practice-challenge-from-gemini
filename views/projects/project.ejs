<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project</title>
    <link rel="stylesheet" href="src/output.css">
</head>

<body class=" w-screen h-screen flex flex-col gap-5 justify-center items-center bg-slate-400">


    <div
        class="grid grid-cols-1 gap-5 w-[80vw] bg-linear-to-r from-zinc-800 via-zinc-400 to-yellow-400 rounded-2xl text-white font-bold md:grid-cols-2 md:w-[90vw]">

        <% for (let d in locals.dataBase) { %>
            <a href="/show" class="flex flex-col justify-between p-5 md:w-[50%]">
                <p><span class="uppercase">s</span>tatus: <%= d.randomStatus %>
                </p>
                <p><span class="uppercase">d</span>ev title: <%= d.title %>
                </p>
                <p><span class="uppercase">t</span>ech stack <%= d.stack %>
                </p>
                <div class="flex justify-between">
                    <p><span class="uppercase">h</span>ealth score: <%= d.healthScore %>
                    </p>
                    <form action="/delete?_method='DELETE'" method="post">
                        <button type="submit" class="uppercase text-red-600">[delete card]</button>
                    </form>
                </div>

            </a>
        <% } %>


    </div>

    <form action="/new" method="get">
        <button type="submit"
            class="p-5 font-bold text-slate-200 rounded-2xl w-full bg-linear-to-r from-zinc-500 via-yellow-300 to-red-500">
            Create new card
        </button>
    </form>

</body>

</html>